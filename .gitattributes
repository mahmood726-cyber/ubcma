# Git attributes — enforce consistent line endings at the git level.
# Pairs with .editorconfig for cross-IDE consistency.

# Auto-detect text files; normalize to LF in the index, native on checkout.
* text=auto eol=lf

# Explicit LF for source code (overrides system core.autocrlf settings).
*.py    text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.jsx   text eol=lf
*.tsx   text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.markdown text eol=lf
*.sh    text eol=lf
*.r     text eol=lf
*.R     text eol=lf
*.rmd   text eol=lf
*.Rmd   text eol=lf

# Windows-native scripts keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary -text
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.db    binary
*.sqlite binary
*.pkl   binary
*.npz   binary
*.parquet binary
